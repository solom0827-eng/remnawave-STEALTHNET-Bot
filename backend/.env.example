# STEALTHNET 3.0 — Backend (для локальной разработки)
# В Docker все переменные приходят из корневого .env через docker-compose.yml

NODE_ENV=development
PORT=5001

# PostgreSQL
DATABASE_URL=postgresql://stealthnet:password@localhost:5432/stealthnet

# JWT (минимум 32 символа)
JWT_SECRET=your_jwt_secret_min_32_chars_change_in_production
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Первый админ
INIT_ADMIN_EMAIL=admin@stealthnet.local
INIT_ADMIN_PASSWORD=

# Remnawave API
REMNA_API_URL=https://panel.example.com
REMNA_ADMIN_TOKEN=
# eGames reverse-proxy cookie (format: name:value). Leave empty if not using eGames.
REMNA_SECRET_KEY=

# CORS
CORS_ORIGIN=http://localhost:5173

# Geo Map (IP geolocation for node/client map)
# Path to MaxMind GeoLite2-City.mmdb (default: ./data/GeoLite2-City.mmdb)
MAXMIND_DB_PATH=
# MaxMind license key for auto-download (optional, get free at maxmind.com)
MAXMIND_LICENSE_KEY=
# Cache TTL in seconds for map data (default: 60)
GEO_CACHE_TTL=60

# Маркетплейс между админами полностью настраивается в админке:
#   /admin/marketplace + /admin/settings → секция «Маркетплейс».
# URL хаба, роль (client/hub), лимиты — зашиты в коде с дефолтами,
# поэтому добавлять переменные в .env специально не требуется.
